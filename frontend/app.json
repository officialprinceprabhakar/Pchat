{
  "expo": {
    "name": "Plexa",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "plexa",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "primaryColor": "#FF3B30",
    "description": "Plexa is a premium social chat where you can join live public rooms, chat 1-on-1 with friends, share photo posts and 24-hour stories, and personalize your profile with badges — all in a modern, mobile-first experience.",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.emergent.modernsocialchat.cbyj0k",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Share photos in chats, posts, and stories",
        "NSCameraUsageDescription": "Take photos for your posts and profile",
        "NSMicrophoneUsageDescription": "Record voice notes for chats"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0A0C"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.emergent.modernsocialchat.cbyj0k",
      "versionCode": 1,
      "permissions": [
        "READ_MEDIA_IMAGES",
        "RECORD_AUDIO",
        "POST_NOTIFICATIONS",
        "INTERNET"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-audio",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0C"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "141ab178-db1b-48f3-a287-535916ad5c19"
      }
    }
  }
}
